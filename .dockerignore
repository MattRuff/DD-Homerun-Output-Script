# The Dockerfile only needs pull_info_from_opp.py, requirements.txt,
# the auth/ package, and scripts/entrypoint.sh.
# Exclude everything else to keep the build context minimal.

# Git
.git
.gitignore

# Docs / meta
*.md
LICENSE
CHANGELOG.md

# Shell wrappers / compose (host-side only, not used inside the container)
docker-run.sh
docker-push.sh
docker-compose.yml

# Host-only helpers (not used inside the container)
scripts/test_auth_methods.py
scripts/run_export.sh

# Python artifacts
__pycache__
*.py[cod]
*.pyo

# Virtual environments
venv/
.venv/
.venv*/
env/

# Auth / secrets — never bake into the image
cookies.txt
token.json
credentials.json
.homerun/

# Generated output
output/
homerun_output/

# macOS
.DS_Store

# Claude Code
.claude/

# Editor / IDE
.idea/
.vscode/
